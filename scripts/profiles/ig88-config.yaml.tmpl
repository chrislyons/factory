# IG-88 Hermes profile template (FCT060)
#
# This file is the SOURCE OF TRUTH for ~/.hermes/profiles/ig88/config.yaml.
# Edit THIS file, not the rendered one. The rendered file is regenerated by
# scripts/hermes-ig88.sh at gateway startup via envsubst, which resolves any
# ${WEBHOOK_SECRET_IG88} placeholders from the process environment (injected
# by infisical-env.sh from the factory Infisical project).
#
# Rendered location: ~/.hermes/profiles/ig88/config.yaml (chmod 600, host-local).
# Do NOT commit the rendered file anywhere — it contains live HMAC secrets.
#
# IG-88 Hermes profile — local MLX inference via dedicated mlx_vlm server
# Model: gemma-4-e4b-it-6bit on :41988 (IG88011 Tier 1 calibration reference)
# Dedicated server (not shared with factory) so IG-88's autonomous workloads
# (scan loops, trade cycles) don't contend with Chris's conversational DMs to Boot/Kelk.
# T2 cloud fallback: google/gemma-4-31b-it via OpenRouter (manual swap when needed).
model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
base_url: http://127.0.0.1:41988/v1
provider: custom
fallback_providers: []
# max_tokens: deliberately oversized. mlx-vlm defaults to 256 when the request
# omits this field, which was the Matrix truncation bug fixed 2026-04-08. This
# value is a "no artificial ceiling" marker — the model will hit its own
# context-window limit (~8k for Gemma 4 E4B) long before 32768 matters, and
# setting it high means we do not need to revisit when context windows grow in
# future model variants. See scripts/hermes-serve.py.
max_tokens: 32768
toolsets:
- terminal
- file
- code_execution
- web
agent:
  max_turns: 200  # FCT059: raised from 90 — IG-88 overnight burned ~25 iterations on a single path typo; budget pressure warnings at 70/90% still trigger at 140/180.
  tool_use_enforcement: none
terminal:
  backend: local
  cwd: /Users/nesbitt/dev/factory/agents/ig88
  persistent_shell: true
display:
  compact: true
  streaming: false
  show_cost: true
memory:
  memory_enabled: false
  user_profile_enabled: false
approvals:
  mode: 'off'
gateway:
  unauthorized_dm_behavior: ignore
platforms:
  matrix:
    enabled: true
    reply_to_mode: first
    extra:
      homeserver: http://localhost:41200
      user_id: '@ig88bot:matrix.org'
      encryption: false
      group_sessions_per_user: true
      unauthorized_dm_behavior: ignore
  # FCT060: Factory Conductor Webhook Memo Protocol.
  # Platform exposes POST /webhooks/memo on 127.0.0.1:41977. HMAC-SHA256 signed
  # requests (X-Webhook-Signature header) only. Secret is injected at render
  # time from the factory Infisical project (WEBHOOK_SECRET_IG88). Rate limit
  # 30 POSTs/minute, max body 1 MiB. Prompt template instructs the agent to
  # reply back through its normal Matrix DM path after processing the memo.
  # Note: IG-88's Matrix ACL is @chrislyons-only per FCT055, so the webhook is
  # the only path by which a non-Chris operator (e.g., a Factory Conductor
  # Claude session) can reach IG-88's reasoning context. HMAC replaces the
  # user-ACL as the trust boundary.
  # See docs/fct/FCT060 for the full architecture and signing workflow.
  webhook:
    enabled: true
    extra:
      host: 127.0.0.1
      port: 41977
      secret: ${WEBHOOK_SECRET_IG88}
      rate_limit: 30
      max_body_bytes: 1048576
      routes:
        memo:
          prompt: |
            Factory Conductor memo from Chris (approved via HMAC signature): {message}

            After completing this memo, post your reply as a regular Matrix message in the Chris<>IG-88 DM room (room_id: !zRnHwXlrVdCfdNbNOx:matrix.org). The reply should be the actual answer or work product the memo asked for, not a meta-acknowledgement.
          deliver: log
# Auxiliary slots: route ALL auxiliary subsystems to the dedicated mlx-vlm-ig88
# on :41988 (IG-88 has its own instance, not the shared :41961). Without these,
# auxiliaries default to provider=auto which falls through to OpenRouter with
# the local model path as the model ID (HTTP 400). See FCT055.
auxiliary:
  vision:
    provider: custom
    base_url: http://127.0.0.1:41988/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  web_extract:
    provider: custom
    base_url: http://127.0.0.1:41988/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  compression:
    provider: custom
    base_url: http://127.0.0.1:41988/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
    summary_provider: custom
    summary_base_url: http://127.0.0.1:41988/v1
    summary_model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  session_search:
    provider: custom
    base_url: http://127.0.0.1:41988/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  skills_hub:
    provider: custom
    base_url: http://127.0.0.1:41988/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  approval:
    provider: custom
    base_url: http://127.0.0.1:41988/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  mcp:
    provider: custom
    base_url: http://127.0.0.1:41988/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  flush_memories:
    provider: custom
    base_url: http://127.0.0.1:41988/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
mcp_servers:
