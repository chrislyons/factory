# Kelk Hermes profile template (FCT060)
#
# This file is the SOURCE OF TRUTH for ~/.hermes/profiles/kelk/config.yaml.
# Edit THIS file, not the rendered one. The rendered file is regenerated by
# scripts/hermes-kelk.sh at gateway startup via envsubst, which resolves any
# ${WEBHOOK_SECRET_KELK} placeholders from the process environment (injected
# by infisical-env.sh from the factory Infisical project).
#
# Rendered location: ~/.hermes/profiles/kelk/config.yaml (chmod 600, host-local).
# Do NOT commit the rendered file anywhere — it contains live HMAC secrets.
#
# Kelk Hermes profile — local MLX-LM only (TOS compliant)
# Model: shared factory mlx_vlm server on :41961 (gemma-4-e4b-it-6bit)
# Previously Qwen3.5-4B on :41962 — replaced because reasoning token waste
# made simple queries take 49s.
model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
base_url: http://127.0.0.1:41961/v1
provider: custom
fallback_providers: []
# max_tokens: "no artificial ceiling" marker. See ig88 profile for rationale.
max_tokens: 32768
toolsets: [terminal, file]
agent:
  max_turns: 200  # FCT059: raised from 90 — IG-88 overnight burned ~25 iterations on a single path typo; budget pressure warnings at 70/90% still trigger at 140/180.
  tool_use_enforcement: none
terminal:
  backend: local
  cwd: /Users/nesbitt/dev/factory/agents/kelk
  persistent_shell: true
display:
  compact: true
  streaming: false
  show_cost: false
memory:
  memory_enabled: false
  user_profile_enabled: false
approvals:
  mode: "off"
gateway: {}
# Auxiliary slots: route ALL auxiliary subsystems (title generation, context
# compression, session search, flush_memories, vision, web_extract, skills_hub,
# approval, mcp) to the local mlx-vlm on :41961 using provider=custom.
# Without these explicit overrides, auxiliaries default to provider=auto which
# falls through to OpenRouter and sends the local model path as the model ID,
# producing HTTP 400 "is not a valid model ID" errors. See FCT055 §5 + FCT057.
auxiliary:
  vision:
    provider: custom
    base_url: http://127.0.0.1:41961/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  web_extract:
    provider: custom
    base_url: http://127.0.0.1:41961/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  compression:
    provider: custom
    base_url: http://127.0.0.1:41961/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
    summary_provider: custom
    summary_base_url: http://127.0.0.1:41961/v1
    summary_model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  session_search:
    provider: custom
    base_url: http://127.0.0.1:41961/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  skills_hub:
    provider: custom
    base_url: http://127.0.0.1:41961/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  approval:
    provider: custom
    base_url: http://127.0.0.1:41961/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  mcp:
    provider: custom
    base_url: http://127.0.0.1:41961/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
  flush_memories:
    provider: custom
    base_url: http://127.0.0.1:41961/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
mcp_servers:
  qdrant-mcp:
    url: http://localhost:41460/mcp
    connect_timeout: 10
  research-mcp:
    url: http://localhost:41470/mcp
    connect_timeout: 10
  graphiti:
    url: http://localhost:41440/sse
    enabled: false
