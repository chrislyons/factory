# Boot Hermes profile template (FCT060)
#
# This file is the SOURCE OF TRUTH for ~/.hermes/profiles/boot/config.yaml.
# Edit THIS file, not the rendered one. The rendered file is regenerated by
# scripts/hermes-boot.sh at gateway startup via envsubst, which resolves any
# ${WEBHOOK_SECRET_BOOT} placeholders from the process environment (injected
# by infisical-env.sh from the factory Infisical project).
#
# Rendered location: ~/.hermes/profiles/boot/config.yaml (chmod 600, host-local).
# Do NOT commit the rendered file anywhere — it contains live HMAC secrets.
model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
base_url: http://127.0.0.1:41961/v1
provider: custom
fallback_providers: []
# max_tokens: "no artificial ceiling" marker. See ig88 profile for rationale.
max_tokens: 32768
toolsets: [terminal, file, code_execution]
agent:
  max_turns: 200  # FCT059: raised from 90 — IG-88 overnight burned ~25 iterations on a single path typo; budget pressure warnings at 70/90% still trigger at 140/180.
  tool_use_enforcement: none
terminal:
  backend: local
  cwd: /Users/nesbitt/dev/factory/agents/boot
  persistent_shell: true
display:
  compact: true
  streaming: false
  show_cost: false
memory:
  memory_enabled: false
  user_profile_enabled: false
approvals:
  mode: "off"
gateway: {}
# Auxiliary slots: route ALL auxiliary subsystems to the local mlx-vlm on
# :41961. Without these, auxiliaries default to provider=auto which falls
# through to OpenRouter with the local model path as the model ID (HTTP 400).
# See FCT055 + Kelk profile for full rationale.
auxiliary:
  vision:
    provider: custom
    base_url: http://127.0.0.1:41961/v1
    model: /Users/nesbitt/models/gemma-4-e4b-it-6bit
