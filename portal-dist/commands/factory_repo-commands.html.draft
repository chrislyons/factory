<main>
  <div class="hero-row">
    <div class="hero">
      <span class="hero-eyebrow">COMMAND REFERENCE</span>
      <h1>factory</h1>
      <p>Multi-agent orchestration platform — Rust coordinator + React portal + Hermes gateways + job registry</p>
    </div>
    <div class="hero-meta"><div class="meta-chip"><span class="meta-chip__label">UPDATED</span><span class="meta-chip__value">2026-04-08</span></div><div class="meta-chip"><span class="meta-chip__label">REPO</span><span class="meta-chip__value">~/dev/factory</span></div></div>
  </div>
  <div class="search-wrap"><span class="search-icon">&#x2315;</span><input class="search-input" type="text" placeholder="Search commands, snippets, or notes…" id="search" autocomplete="off" spellcheck="false"><span class="search-count" id="search-count"></span><button class="search-clear" id="search-clear" title="Clear search">&#xd7;</button></div>

  <section class="surface-card section-card" data-section="portal"><button class="section-header" type="button" aria-expanded="true"><span class="section-arrow">&#x25BC;</span><span class="section-title">Portal</span><span class="section-count">6</span></button><div class="section-body"><table class="command-table"><thead><tr><th>Task</th><th>Command / Snippet</th><th>Description</th></tr></thead><tbody>
    <tr class="command-row" data-search="dev server cd portal && pnpm dev start vite dev server (port 5173)"><td><div class="task-text">Dev server</div></td><td><button class="value-block value-block--shell" data-copy="cd portal && pnpm dev" title="Copy value"><code class="value-text">cd portal &amp;&amp; pnpm dev</code></button></td><td class="desc-text">Start Vite dev server (port 5173)</td></tr>
    <tr class="command-row" data-search="build cd portal && pnpm build production build to portal/dist/"><td><div class="task-text">Build</div></td><td><button class="value-block value-block--shell" data-copy="cd portal && pnpm build" title="Copy value"><code class="value-text">cd portal &amp;&amp; pnpm build</code></button></td><td class="desc-text">Production build to portal/dist/</td></tr>
    <tr class="command-row" data-search="test cd portal && pnpm test run vitest suite (17 tests, 9 files)"><td><div class="task-text">Test</div></td><td><button class="value-block value-block--shell" data-copy="cd portal && pnpm test" title="Copy value"><code class="value-text">cd portal &amp;&amp; pnpm test</code></button></td><td class="desc-text">Run Vitest suite (17 tests, 9 files)</td></tr>
    <tr class="command-row" data-search="deploy cd portal && make sync rsync dist/ to whitebox :41910"><td><div class="task-text">Deploy</div></td><td><button class="value-block value-block--shell" data-copy="cd portal && make sync" title="Copy value"><code class="value-text">cd portal &amp;&amp; make sync</code></button></td><td class="desc-text">Build + git push + rsync dist/ to Whitebox :41910</td></tr>
    <tr class="command-row" data-search="typecheck cd portal && pnpm exec tsc --noEmit typescript validation"><td><div class="task-text">Typecheck</div></td><td><button class="value-block value-block--shell" data-copy="cd portal && pnpm exec tsc --noEmit" title="Copy value"><code class="value-text">cd portal &amp;&amp; pnpm exec tsc --noEmit</code></button></td><td class="desc-text">TypeScript validation</td></tr>
    <tr class="command-row" data-search="install deps cd portal && pnpm install install portal dependencies"><td><div class="task-text">Install deps</div></td><td><button class="value-block value-block--shell" data-copy="cd portal && pnpm install" title="Copy value"><code class="value-text">cd portal &amp;&amp; pnpm install</code></button></td><td class="desc-text">Install portal dependencies</td></tr>
  </tbody></table></div></section>

  <section class="surface-card section-card" data-section="coordinator"><button class="section-header collapsed" type="button" aria-expanded="false"><span class="section-arrow">&#x25BC;</span><span class="section-title">Coordinator (Rust)</span><span class="section-count">5</span></button><div class="section-body collapsed"><table class="command-table"><thead><tr><th>Task</th><th>Command / Snippet</th><th>Description</th></tr></thead><tbody>
    <tr class="command-row" data-search="build cd coordinator && cargo build compile coordinator-rs debug"><td><div class="task-text">Build</div></td><td><button class="value-block value-block--shell" data-copy="cd coordinator && cargo build" title="Copy value"><code class="value-text">cd coordinator &amp;&amp; cargo build</code></button></td><td class="desc-text">Compile coordinator-rs (debug)</td></tr>
    <tr class="command-row" data-search="test cd coordinator && cargo test run 78 tests"><td><div class="task-text">Test</div></td><td><button class="value-block value-block--shell" data-copy="cd coordinator && cargo test" title="Copy value"><code class="value-text">cd coordinator &amp;&amp; cargo test</code></button></td><td class="desc-text">Run test suite (78 tests as of FCT059)</td></tr>
    <tr class="command-row" data-search="release build cd coordinator && cargo build --release optimized binary for whitebox"><td><div class="task-text">Release build</div></td><td><button class="value-block value-block--shell" data-copy="cd coordinator && cargo build --release" title="Copy value"><code class="value-text">cd coordinator &amp;&amp; cargo build --release</code></button></td><td class="desc-text">Optimized binary for Whitebox</td></tr>
    <tr class="command-row" data-search="check cd coordinator && cargo check fast compile check without linking"><td><div class="task-text">Check</div></td><td><button class="value-block value-block--shell" data-copy="cd coordinator && cargo check" title="Copy value"><code class="value-text">cd coordinator &amp;&amp; cargo check</code></button></td><td class="desc-text">Fast compile check (no linking)</td></tr>
    <tr class="command-row" data-search="clippy cd coordinator && cargo clippy lint with clippy warnings"><td><div class="task-text">Clippy</div></td><td><button class="value-block value-block--shell" data-copy="cd coordinator && cargo clippy" title="Copy value"><code class="value-text">cd coordinator &amp;&amp; cargo clippy</code></button></td><td class="desc-text">Lint with Clippy warnings</td></tr>
  </tbody></table></div></section>

  <section class="surface-card section-card" data-section="jobs"><button class="section-header collapsed" type="button" aria-expanded="false"><span class="section-arrow">&#x25BC;</span><span class="section-title">Job Registry</span><span class="section-count">3</span></button><div class="section-body collapsed"><table class="command-table"><thead><tr><th>Task</th><th>Command / Snippet</th><th>Description</th></tr></thead><tbody>
    <tr class="command-row" data-search="build jobs.json python3 scripts/build-jobs-json.py compile yaml registry to jobs.json"><td><div class="task-text">Build jobs.json</div></td><td><button class="value-block value-block--shell" data-copy="python3 scripts/build-jobs-json.py" title="Copy value"><code class="value-text">python3 scripts/build-jobs-json.py</code></button></td><td class="desc-text">Compile YAML registry to jobs.json</td></tr>
    <tr class="command-row" data-search="validate registry python3 scripts/build-jobs-json.py --validate dry-run validation of job yaml"><td><div class="task-text">Validate registry</div></td><td><button class="value-block value-block--shell" data-copy="python3 scripts/build-jobs-json.py --validate" title="Copy value"><code class="value-text">python3 scripts/build-jobs-json.py --validate</code></button></td><td class="desc-text">Dry-run validation of job YAML</td></tr>
    <tr class="command-row" data-search="list jobs ls jobs/*/*.yaml count job files across domains"><td><div class="task-text">List jobs</div></td><td><button class="value-block value-block--shell" data-copy="ls jobs/*/*.yaml | wc -l" title="Copy value"><code class="value-text">ls jobs/*/*.yaml | wc -l</code></button></td><td class="desc-text">Count job files across domains</td></tr>
  </tbody></table></div></section>

  <section class="surface-card section-card" data-section="infra"><button class="section-header collapsed" type="button" aria-expanded="false"><span class="section-arrow">&#x25BC;</span><span class="section-title">Infrastructure</span><span class="section-count">13</span></button><div class="section-body collapsed"><table class="command-table"><thead><tr><th>Task</th><th>Command / Snippet</th><th>Description</th></tr></thead><tbody>
    <tr class="command-row" data-search="all services launchctl list grep bootindustries list all factory launchd services"><td><div class="task-text">All services</div></td><td><button class="value-block value-block--shell" data-copy="launchctl list | grep bootindustries" title="Copy value"><code class="value-text">launchctl list | grep bootindustries</code></button></td><td class="desc-text">List all factory launchd services (on Whitebox host)</td></tr>
    <tr class="command-row" data-search="coordinator status launchctl list grep coordinator check coordinator launchd service"><td><div class="task-text">Coordinator status</div></td><td><button class="value-block value-block--shell" data-copy="launchctl list | grep coordinator-rs" title="Copy value"><code class="value-text">launchctl list | grep coordinator-rs</code></button></td><td class="desc-text">Check coordinator-rs launchd service PID and exit status</td></tr>
    <tr class="command-row" data-search="41 port audit 41xxx listening ports whitebox"><td><div class="task-text">Port audit (41xxx)</div></td><td><button class="value-block value-block--shell" data-copy="lsof -nP -iTCP -sTCP:LISTEN | awk 'NR==1 || /:41[0-9]{3}/'" title="Copy value"><code class="value-text">lsof -nP -iTCP -sTCP:LISTEN | awk '/:41[0-9]{3}/'</code></button></td><td class="desc-text">Audit all TCP listeners in the 41xxx factory port range (WHB008)</td></tr>
    <tr class="command-row" data-search="portal status curl 41910 check portal http response"><td><div class="task-text">Portal status</div></td><td><button class="value-block value-block--shell" data-copy="curl -so /dev/null -w '%{http_code}' http://127.0.0.1:41910/" title="Copy value"><code class="value-text">curl -so /dev/null -w "%{http_code}" http://127.0.0.1:41910/</code></button></td><td class="desc-text">Check portal Caddy HTTP response (WHB008)</td></tr>
    <tr class="command-row" data-search="gsd status curl 41911 jobs.json check gsd sidecar"><td><div class="task-text">GSD status</div></td><td><button class="value-block value-block--shell" data-copy="curl -so /dev/null -w '%{http_code}' http://127.0.0.1:41911/jobs.json" title="Copy value"><code class="value-text">curl -so /dev/null -w "%{http_code}" http://127.0.0.1:41911/jobs.json</code></button></td><td class="desc-text">Check GSD sidecar (jobs.json endpoint, :41911)</td></tr>
    <tr class="command-row" data-search="auth status launchctl list factory-auth check auth sidecar"><td><div class="task-text">Auth status</div></td><td><button class="value-block value-block--shell" data-copy="launchctl list | grep factory-auth" title="Copy value"><code class="value-text">launchctl list | grep factory-auth</code></button></td><td class="desc-text">Check auth sidecar (:41914) — exit code 0 = healthy</td></tr>
    <tr class="command-row" data-search="pantalaimon health curl 41200 check e2ee proxy"><td><div class="task-text">Pantalaimon</div></td><td><button class="value-block value-block--shell" data-copy="curl -sI http://127.0.0.1:41200/_matrix/client/versions | head -1" title="Copy value"><code class="value-text">curl -sI http://127.0.0.1:41200/_matrix/client/versions | head -1</code></button></td><td class="desc-text">Check Pantalaimon E2EE proxy (:41200, WHB019)</td></tr>
    <tr class="command-row" data-search="mlx-vlm factory curl 41961 health shared inference for boot kelk"><td><div class="task-text">mlx-vlm-factory</div></td><td><button class="value-block value-block--shell" data-copy="curl -s http://127.0.0.1:41961/health" title="Copy value"><code class="value-text">curl -s http://127.0.0.1:41961/health</code></button></td><td class="desc-text">Shared MLX-VLM inference (:41961) — serves Boot and Kelk since FCT054</td></tr>
    <tr class="command-row" data-search="mlx-vlm ig88 curl 41988 health dedicated ig88 inference"><td><div class="task-text">mlx-vlm-ig88</div></td><td><button class="value-block value-block--shell" data-copy="curl -s http://127.0.0.1:41988/health" title="Copy value"><code class="value-text">curl -s http://127.0.0.1:41988/health</code></button></td><td class="desc-text">Dedicated MLX-VLM inference for IG-88 (:41988, WHB018) — gemma-4-e4b-it-6bit</td></tr>
    <tr class="command-row" data-search="qdrant status curl 41450 collections vector db"><td><div class="task-text">Qdrant</div></td><td><button class="value-block value-block--shell" data-copy="curl -s http://127.0.0.1:41450/collections" title="Copy value"><code class="value-text">curl -s http://127.0.0.1:41450/collections</code></button></td><td class="desc-text">Qdrant vector DB collections (:41450, WHB019)</td></tr>
    <tr class="command-row" data-search="falkordb redis 41430 graph db backend"><td><div class="task-text">FalkorDB</div></td><td><button class="value-block value-block--shell" data-copy="redis-cli -p 41430 PING" title="Copy value"><code class="value-text">redis-cli -p 41430 PING</code></button></td><td class="desc-text">FalkorDB graph DB backend (:41430, WHB019)</td></tr>
    <tr class="command-row" data-search="port map cat infra/ports.csv view master port allocation table"><td><div class="task-text">Port map</div></td><td><button class="value-block value-block--shell" data-copy="cat infra/ports.csv" title="Copy value"><code class="value-text">cat infra/ports.csv</code></button></td><td class="desc-text">Master port allocation table (see WHB008 for canonical)</td></tr>
    <tr class="command-row" data-search="regen index json regenerate docs index after rsync delete"><td><div class="task-text">Regen index.json</div></td><td><button class="value-block value-block--shell" data-copy="cd ~/dev/factory/portal/dist && python3 ../src/generate_index.py --repos-dir ../repos --output ./index.json" title="Copy value"><code class="value-text">cd portal/dist &amp;&amp; python3 ../src/generate_index.py --repos-dir ../repos --output ./index.json</code></button></td><td class="desc-text">Regenerate docs index.json (required after rsync --delete)</td></tr>
  </tbody></table></div></section>

  <section class="surface-card section-card" data-section="hermes"><button class="section-header collapsed" type="button" aria-expanded="false"><span class="section-arrow">&#x25BC;</span><span class="section-title">Hermes Gateways (FCT052, FCT059)</span><span class="section-count">9</span></button><div class="section-body collapsed"><table class="command-table"><thead><tr><th>Task</th><th>Command / Snippet</th><th>Description</th></tr></thead><tbody>
    <tr class="command-row" data-search="hermes all gateways launchctl list grep hermes-"><td><div class="task-text">All gateway PIDs</div></td><td><button class="value-block value-block--shell" data-copy="launchctl list | grep hermes-" title="Copy value"><code class="value-text">launchctl list | grep hermes-</code></button></td><td class="desc-text">All three Hermes gateway PIDs and exit statuses</td></tr>
    <tr class="command-row" data-search="restart boot gateway launchctl kickstart bootindustries hermes-boot"><td><div class="task-text">Restart Boot</div></td><td><button class="value-block value-block--shell" data-copy="launchctl kickstart -k gui/$UID/com.bootindustries.hermes-boot" title="Copy value"><code class="value-text">launchctl kickstart -k gui/$UID/com.bootindustries.hermes-boot</code></button></td><td class="desc-text">Kickstart Boot gateway (FCT059 C1b: runs `hermes --profile boot gateway run --replace`)</td></tr>
    <tr class="command-row" data-search="restart kelk gateway launchctl kickstart bootindustries hermes-kelk"><td><div class="task-text">Restart Kelk</div></td><td><button class="value-block value-block--shell" data-copy="launchctl kickstart -k gui/$UID/com.bootindustries.hermes-kelk" title="Copy value"><code class="value-text">launchctl kickstart -k gui/$UID/com.bootindustries.hermes-kelk</code></button></td><td class="desc-text">Kickstart Kelk gateway (runs on shared mlx-vlm-factory :41961)</td></tr>
    <tr class="command-row" data-search="restart ig88 gateway launchctl kickstart bootindustries hermes-ig88"><td><div class="task-text">Restart IG-88</div></td><td><button class="value-block value-block--shell" data-copy="launchctl kickstart -k gui/$UID/com.bootindustries.hermes-ig88" title="Copy value"><code class="value-text">launchctl kickstart -k gui/$UID/com.bootindustries.hermes-ig88</code></button></td><td class="desc-text">Kickstart IG-88 gateway (FCT053 dedicated mlx-vlm-ig88 :41988)</td></tr>
    <tr class="command-row" data-search="boot gateway log tail hermes-boot.log"><td><div class="task-text">Boot gateway log</div></td><td><button class="value-block value-block--shell" data-copy="tail -n 30 ~/Library/Logs/factory/hermes-boot.log" title="Copy value"><code class="value-text">tail -n 30 ~/Library/Logs/factory/hermes-boot.log</code></button></td><td class="desc-text">Launchd stderr log for Boot gateway (tool-call traces, errors)</td></tr>
    <tr class="command-row" data-search="boot errors log profile errors"><td><div class="task-text">Boot errors.log</div></td><td><button class="value-block value-block--shell" data-copy="tail -n 20 ~/.hermes/profiles/boot/logs/errors.log" title="Copy value"><code class="value-text">tail -n 20 ~/.hermes/profiles/boot/logs/errors.log</code></button></td><td class="desc-text">Hermes profile errors.log for Boot (auxiliary routing failures, provider errors)</td></tr>
    <tr class="command-row" data-search="boot profile config"><td><div class="task-text">Boot profile config</div></td><td><button class="value-block value-block--shell" data-copy="cat ~/.hermes/profiles/boot/config.yaml" title="Copy value"><code class="value-text">cat ~/.hermes/profiles/boot/config.yaml</code></button></td><td class="desc-text">Boot Hermes profile config (provider: custom pin, auxiliary overrides, platforms)</td></tr>
    <tr class="command-row" data-search="hermes provider pin check provider custom"><td><div class="task-text">Provider pin check</div></td><td><button class="value-block value-block--shell" data-copy="for p in boot kelk ig88; do printf '%-8s ' $p; grep -E '^provider:' ~/.hermes/profiles/$p/config.yaml; done" title="Copy value"><code class="value-text">for p in boot kelk ig88; do grep ^provider: ~/.hermes/profiles/$p/config.yaml; done</code></button></td><td class="desc-text">Verify all three profiles pin provider: custom (FCT055 RC-1 guard)</td></tr>
    <tr class="command-row" data-search="hermes max turns config max_turns"><td><div class="task-text">Max turns check</div></td><td><button class="value-block value-block--shell" data-copy="for p in boot kelk ig88; do printf '%-8s ' $p; grep -E 'max_turns:' ~/.hermes/profiles/$p/config.yaml; done" title="Copy value"><code class="value-text">for p in boot kelk ig88; do grep max_turns: ~/.hermes/profiles/$p/config.yaml; done</code></button></td><td class="desc-text">Verify agent.max_turns: 200 (FCT059 A3, raised from 90)</td></tr>
  </tbody></table></div></section>

  <section class="surface-card section-card" data-section="webhook"><button class="section-header collapsed" type="button" aria-expanded="false"><span class="section-arrow">&#x25BC;</span><span class="section-title">Factory Conductor Webhooks (FCT060)</span><span class="section-count">8</span></button><div class="section-body collapsed"><table class="command-table"><thead><tr><th>Task</th><th>Command / Snippet</th><th>Description</th></tr></thead><tbody>
    <tr class="command-row" data-search="webhook health boot 41951"><td><div class="task-text">Boot webhook health</div></td><td><button class="value-block value-block--shell" data-copy="curl -s http://127.0.0.1:41951/health" title="Copy value"><code class="value-text">curl -s http://127.0.0.1:41951/health</code></button></td><td class="desc-text">Boot webhook platform health (:41951, FCT060)</td></tr>
    <tr class="command-row" data-search="webhook health kelk 41952"><td><div class="task-text">Kelk webhook health</div></td><td><button class="value-block value-block--shell" data-copy="curl -s http://127.0.0.1:41952/health" title="Copy value"><code class="value-text">curl -s http://127.0.0.1:41952/health</code></button></td><td class="desc-text">Kelk webhook platform health (:41952, FCT060)</td></tr>
    <tr class="command-row" data-search="webhook health ig88 41977"><td><div class="task-text">IG-88 webhook health</div></td><td><button class="value-block value-block--shell" data-copy="curl -s http://127.0.0.1:41977/health" title="Copy value"><code class="value-text">curl -s http://127.0.0.1:41977/health</code></button></td><td class="desc-text">IG-88 webhook platform health (:41977, FCT060)</td></tr>
    <tr class="command-row" data-search="webhook all three health probe all factory conductor"><td><div class="task-text">All three webhooks</div></td><td><button class="value-block value-block--shell" data-copy="for p in 41951 41952 41977; do printf 'port %s: ' $p; curl -s http://127.0.0.1:$p/health; echo; done" title="Copy value"><code class="value-text">for p in 41951 41952 41977; do curl -s http://127.0.0.1:$p/health; done</code></button></td><td class="desc-text">Fan-out health probe for all three webhook platforms</td></tr>
    <tr class="command-row" data-search="post memo boot factory conductor"><td><div class="task-text">Post memo → Boot</div></td><td><button class="value-block value-block--shell" data-copy="scripts/infisical-env.sh factory -- scripts/post-memo.sh boot 'Your memo here'" title="Copy value"><code class="value-text">infisical-env.sh factory -- post-memo.sh boot 'memo text'</code></button></td><td class="desc-text">Send signed Factory Conductor memo to Boot via webhook (FCT060)</td></tr>
    <tr class="command-row" data-search="post memo kelk factory conductor"><td><div class="task-text">Post memo → Kelk</div></td><td><button class="value-block value-block--shell" data-copy="scripts/infisical-env.sh factory -- scripts/post-memo.sh kelk 'Your memo here'" title="Copy value"><code class="value-text">infisical-env.sh factory -- post-memo.sh kelk 'memo text'</code></button></td><td class="desc-text">Send signed Factory Conductor memo to Kelk via webhook</td></tr>
    <tr class="command-row" data-search="post memo ig88 factory conductor"><td><div class="task-text">Post memo → IG-88</div></td><td><button class="value-block value-block--shell" data-copy="scripts/infisical-env.sh factory -- scripts/post-memo.sh ig88 'Your memo here'" title="Copy value"><code class="value-text">infisical-env.sh factory -- post-memo.sh ig88 'memo text'</code></button></td><td class="desc-text">Send signed Factory Conductor memo to IG-88 via webhook</td></tr>
    <tr class="command-row" data-search="memo from stdin factory conductor long body"><td><div class="task-text">Memo from stdin</div></td><td><button class="value-block value-block--shell" data-copy="cat my-long-memo.md | scripts/infisical-env.sh factory -- scripts/post-memo.sh boot -" title="Copy value"><code class="value-text">cat memo.md | infisical-env.sh factory -- post-memo.sh boot -</code></button></td><td class="desc-text">Pipe a multi-line memo body from stdin (use - as the body arg)</td></tr>
  </tbody></table></div></section>

  <section class="surface-card section-card" data-section="agents"><button class="section-header collapsed" type="button" aria-expanded="false"><span class="section-arrow">&#x25BC;</span><span class="section-title">Agent Management</span><span class="section-count">5</span></button><div class="section-body collapsed"><table class="command-table"><thead><tr><th>Task</th><th>Command / Snippet</th><th>Description</th></tr></thead><tbody>
    <tr class="command-row" data-search="agent config cat agents/ig88/config/agent-config.yaml view agent configuration"><td><div class="task-text">Agent config</div></td><td><button class="value-block value-block--shell" data-copy="cat agents/ig88/config/agent-config.yaml" title="Copy value"><code class="value-text">cat agents/ig88/config/agent-config.yaml</code></button></td><td class="desc-text">Coordinator agent config (agents, rooms, settings — gitignored, per-host)</td></tr>
    <tr class="command-row" data-search="runtime state ig88 check runtime state and token usage"><td><div class="task-text">IG-88 runtime state</div></td><td><button class="value-block value-block--shell" data-copy="cat ~/.config/ig88/runtime-state.json" title="Copy value"><code class="value-text">cat ~/.config/ig88/runtime-state.json</code></button></td><td class="desc-text">Check IG-88 runtime state and token usage</td></tr>
    <tr class="command-row" data-search="run events list ig88 run logs"><td><div class="task-text">Run events</div></td><td><button class="value-block value-block--shell" data-copy="ls -la ~/.config/ig88/runs/" title="Copy value"><code class="value-text">ls -la ~/.config/ig88/runs/</code></button></td><td class="desc-text">List IG-88 run event logs</td></tr>
    <tr class="command-row" data-search="matrix mcp boot :41401"><td><div class="task-text">Matrix MCP Boot</div></td><td><button class="value-block value-block--shell" data-copy="curl -sI http://127.0.0.1:41401/mcp | head -1" title="Copy value"><code class="value-text">curl -sI http://127.0.0.1:41401/mcp | head -1</code></button></td><td class="desc-text">Matrix MCP daemon for Boot user identity (:41401, WHB019)</td></tr>
    <tr class="command-row" data-search="matrix mcp coord :41400"><td><div class="task-text">Matrix MCP Coord</div></td><td><button class="value-block value-block--shell" data-copy="curl -sI http://127.0.0.1:41400/mcp | head -1" title="Copy value"><code class="value-text">curl -sI http://127.0.0.1:41400/mcp | head -1</code></button></td><td class="desc-text">Matrix MCP daemon for Coordinator user identity (:41400, WHB019)</td></tr>
  </tbody></table></div></section>

  <section class="surface-card section-card" data-section="console"><button class="section-header collapsed" type="button" aria-expanded="false"><span class="section-arrow">&#x25BC;</span><span class="section-title">Agent Console (FCT048)</span><span class="section-count">4</span></button><div class="section-body collapsed"><table class="command-table"><thead><tr><th>Task</th><th>Command / Snippet</th><th>Description</th></tr></thead><tbody>
    <tr class="command-row" data-search="attach boot console scripts/agent-console.sh boot --attach read-write"><td><div class="task-text">Attach Boot console</div></td><td><button class="value-block value-block--shell" data-copy="scripts/agent-console.sh boot --attach" title="Copy value"><code class="value-text">scripts/agent-console.sh boot --attach</code></button></td><td class="desc-text">Read-write attach to Boot agent tmux session (if agent_console_enabled)</td></tr>
    <tr class="command-row" data-search="watch boot console scripts/agent-console.sh boot --watch read-only"><td><div class="task-text">Watch Boot console</div></td><td><button class="value-block value-block--shell" data-copy="scripts/agent-console.sh boot --watch" title="Copy value"><code class="value-text">scripts/agent-console.sh boot --watch</code></button></td><td class="desc-text">Read-only observer mode (no accidental input)</td></tr>
    <tr class="command-row" data-search="list agent sessions"><td><div class="task-text">List sessions</div></td><td><button class="value-block value-block--shell" data-copy="scripts/agent-console.sh --list" title="Copy value"><code class="value-text">scripts/agent-console.sh --list</code></button></td><td class="desc-text">List all active agent tmux sessions</td></tr>
    <tr class="command-row" data-search="create agent session"><td><div class="task-text">Create session</div></td><td><button class="value-block value-block--shell" data-copy="scripts/agent-console.sh boot --create" title="Copy value"><code class="value-text">scripts/agent-console.sh boot --create</code></button></td><td class="desc-text">Manually create agent tmux session</td></tr>
  </tbody></table></div></section>

  <section class="surface-card section-card" data-section="sync"><button class="section-header collapsed" type="button" aria-expanded="false"><span class="section-arrow">&#x25BC;</span><span class="section-title">Git &amp; Sync</span><span class="section-count">5</span></button><div class="section-body collapsed"><table class="command-table"><thead><tr><th>Task</th><th>Command / Snippet</th><th>Description</th></tr></thead><tbody>
    <tr class="command-row" data-search="current branch git status"><td><div class="task-text">Current branch</div></td><td><button class="value-block value-block--shell" data-copy="git branch --show-current && git log --oneline -5" title="Copy value"><code class="value-text">git branch --show-current &amp;&amp; git log --oneline -5</code></button></td><td class="desc-text">Show current branch and last 5 commits</td></tr>
    <tr class="command-row" data-search="push to whitebox git push whitebox main push factory source to whitebox remote"><td><div class="task-text">Push to Whitebox</div></td><td><button class="value-block value-block--shell" data-copy="git push whitebox main" title="Copy value"><code class="value-text">git push whitebox main</code></button></td><td class="desc-text">Push factory source to Whitebox git remote (working-tree auto-updates)</td></tr>
    <tr class="command-row" data-search="rsync deploy dist whitebox"><td><div class="task-text">Rsync deploy</div></td><td><button class="value-block value-block--shell" data-copy="rsync -avz --delete portal/dist/ nesbitt@100.88.222.111:~/dev/factory/portal/dist/" title="Copy value"><code class="value-text">rsync -avz --delete portal/dist/ nesbitt@whitebox:~/dev/factory/portal/dist/</code></button></td><td class="desc-text">Deploy dist/ to Whitebox (caution: --delete removes index.json)</td></tr>
    <tr class="command-row" data-search="full deploy build push rsync regen index complete pipeline"><td><div class="task-text">Full deploy</div></td><td><button class="value-block value-block--text" data-copy="cd portal && pnpm build && cd .. && git push whitebox main && rsync -avz --delete portal/dist/ nesbitt@100.88.222.111:~/dev/factory/portal/dist/ && ssh whitebox 'cd ~/dev/factory/portal/dist && python3 ../src/generate_index.py --repos-dir ../repos --output ./index.json'" title="Copy value"><code class="value-text">pnpm build &amp;&amp; git push whitebox &amp;&amp; rsync --delete dist/ &amp;&amp; ssh regen index.json</code></button></td><td class="desc-text">Build + push + rsync + regenerate index.json</td></tr>
    <tr class="command-row" data-search="check divergence whitebox git log"><td><div class="task-text">Check divergence</div></td><td><button class="value-block value-block--shell" data-copy="ssh whitebox 'cd ~/dev/factory && git log --oneline -3'" title="Copy value"><code class="value-text">ssh whitebox 'cd ~/dev/factory &amp;&amp; git log --oneline -3'</code></button></td><td class="desc-text">Compare Whitebox HEAD with local</td></tr>
  </tbody></table></div></section>

  <section class="surface-card section-card" data-section="docs"><button class="section-header collapsed" type="button" aria-expanded="false"><span class="section-arrow">&#x25BC;</span><span class="section-title">Documentation</span><span class="section-count">4</span></button><div class="section-body collapsed"><table class="command-table"><thead><tr><th>Task</th><th>Command / Snippet</th><th>Description</th></tr></thead><tbody>
    <tr class="command-row" data-search="latest fct docs ls -1 docs/fct/ tail list 5 most recent fct docs"><td><div class="task-text">Latest FCT docs</div></td><td><button class="value-block value-block--shell" data-copy="ls -1 docs/fct/ | sort -V | tail -6" title="Copy value"><code class="value-text">ls -1 docs/fct/ | sort -V | tail -6</code></button></td><td class="desc-text">List 6 most recent FCT docs (60+ total as of FCT060)</td></tr>
    <tr class="command-row" data-search="search docs grep -rl topic docs fct"><td><div class="task-text">Search docs</div></td><td><button class="value-block value-block--shell" data-copy="grep -rl 'TOPIC' docs/fct/" title="Copy value"><code class="value-text">grep -rl 'TOPIC' docs/fct/</code></button></td><td class="desc-text">Search FCT docs by keyword</td></tr>
    <tr class="command-row" data-search="reindex projects vault"><td><div class="task-text">Reindex projects vault</div></td><td><button class="value-block value-block--shell" data-copy="~/dev/scripts/reindex-vault.sh" title="Copy value"><code class="value-text">~/dev/scripts/reindex-vault.sh</code></button></td><td class="desc-text">Reindex Qdrant projects-vault</td></tr>
    <tr class="command-row" data-search="reindex research vault"><td><div class="task-text">Reindex research vault</div></td><td><button class="value-block value-block--shell" data-copy="~/dev/scripts/reindex-research-vault.sh" title="Copy value"><code class="value-text">~/dev/scripts/reindex-research-vault.sh</code></button></td><td class="desc-text">Reindex Qdrant research-vault</td></tr>
  </tbody></table></div></section>
</main>

