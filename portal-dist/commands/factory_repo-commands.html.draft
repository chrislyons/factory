<body>
<header class="site-header">
  <div class="site-header__inner">
    <div class="brand">
      <a class="brand__title" href="/pages/docs.html">dreamfactory</a>
    </div>
    <div class="header-actions"><button class="export-btn" id="export-btn" title="Copy visible results to clipboard as markdown">Export to Markdown</button></div>
  </div>
