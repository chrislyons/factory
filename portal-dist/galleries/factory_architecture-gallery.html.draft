  <section class="callout-grid"><article class="surface-card callout callout--info"><h2>Diagram Collection</h2><p>9 architectural diagrams covering agent model assignments, message routing, autoscope loop governance, autonomous loop roadmap, loop execution cycle, machine topology, Whitebox service map, Factory Conductor webhook memo protocol (FCT060), and deferred expert pool. Click headers to expand/collapse. Press a to expand all, Esc to collapse all.</p></article></section>
  <section class="section-block" data-section="agent-architecture"><div class="section-heading"><span>Agent Architecture</span></div><div class="diagram-stack"><article class="surface-card diagram-card" id="agent-model-assignments" data-diagram-id="agent-model-assignments"><button class="diagram-header" type="button" aria-expanded="true"><span class="diagram-arrow">&#9660;</span><span class="diagram-header__copy"><span class="diagram-title">Agent Stack and Model Assignments</span><p class="diagram-description">Three live agents on Hermes gateway mode, unified on gemma-4-e4b-it-6bit (FCT054, FCT059)</p></span><span class="diagram-kind">FLOWCHART</span></button><div class="diagram-content"><div class="diagram-canvas"><div class="diagram-loading">Rendering diagram...</div><script type="application/json" class="mermaid-source">"flowchart LR\n    subgraph LIVE[\"Live Agents (Hermes gateway mode)\"]\n        BOOT[\"Boot\\nOps and Dev\\n@boot.industries\"]\n        KELK[\"Kelk\\nPersonal\\n@sir.kelk\"]\n        IG88[\"IG-88\\nTrading\\n@ig88bot\"]\n    end\n\n    subgraph RESERVED[\"Reserved (no profile yet)\"]\n        NAN_AGENT[\"Nan\\nObserver\\nslot :41963\"]\n        XAMM[\"Xamm\\nBonsai\\nslot :41964\"]\n    end\n\n    subgraph RUNTIME[\"Unified Runtime (FCT059 C1b)\"]\n        HERMES[\"Hermes v0.6 gateway\\nmatrix-nio + Pantalaimon\\nper-agent profile\"]\n    end\n\n    subgraph INFERENCE[\"MLX-VLM Inference (FCT054 consolidation)\"]\n        FACTORY_INF[\"mlx-vlm-factory\\n:41961\\ngemma-4-e4b-it-6bit\\n(Boot + Kelk)\"]\n        IG88_INF[\"mlx-vlm-ig88\\n:41988\\ngemma-4-e4b-it-6bit\\n(dedicated)\"]\n    end\n\n    subgraph WEBHOOK[\"Factory Conductor Webhooks (FCT060)\"]\n        WH_BOOT[\"Boot :41951\\n/webhooks/memo\"]\n        WH_KELK[\"Kelk :41952\\n/webhooks/memo\"]\n        WH_IG88[\"IG-88 :41977\\n/webhooks/memo\"]\n    end\n\n    subgraph ONDEMAND[\"On-Demand / Planned\"]\n        Q9B[\"Reasoning 9B\\n:41966\\n(on-demand)\"]\n    end\n\n    subgraph SHARED[\"Shared Modules\"]\n        EMBED[\"nomic-embed-text\\nEmbeddings (Ollama :11434)\"]\n    end\n\n    BOOT --> HERMES\n    KELK --> HERMES\n    IG88 --> HERMES\n    HERMES --> FACTORY_INF\n    HERMES --> IG88_INF\n    BOOT -.-> WH_BOOT\n    KELK -.-> WH_KELK\n    IG88 -.-> WH_IG88\n\n    classDef agent fill:#e94560,stroke:#c73e54,color:#fff\n    classDef reserved fill:#718096,stroke:#4a5568,color:#fff\n    classDef runtime fill:#38a169,stroke:#276749,color:#fff\n    classDef model fill:#533483,stroke:#422669,color:#fff\n    classDef shared fill:#319795,stroke:#285e61,color:#fff\n    classDef ondemand fill:#d69e2e,stroke:#b7791f,color:#000\n    classDef webhook fill:#2b6cb0,stroke:#2c5282,color:#fff\n\n    class BOOT,KELK,IG88 agent\n    class NAN_AGENT,XAMM reserved\n    class HERMES runtime\n    class FACTORY_INF,IG88_INF model\n    class EMBED shared\n    class Q9B ondemand\n    class WH_BOOT,WH_KELK,WH_IG88 webhook"</script></div></div></article><article class="surface-card diagram-card" id="reasoning-escalation" data-diagram-id="reasoning-escalation"><button class="diagram-header" type="button" aria-expanded="true"><span class="diagram-arrow">&#9660;</span><span class="diagram-header__copy"><span class="diagram-title">Agent Collaboration and Message Routing</span><p class="diagram-description">Matrix event routing via coordinator-rs, peer handoffs, unified inference layer (FCT054+FCT059)</p></span><span class="diagram-kind">FLOWCHART</span></button><div class="diagram-content"><div class="diagram-canvas"><div class="diagram-loading">Rendering diagram...</div><script type="application/json" class="mermaid-source">"flowchart LR\n    MSG[\"Matrix message\\nor webhook memo\"] --> ROUTING\n\n    subgraph ROUTING[\"Routing Layer\"]\n        COORD[\"coordinator-rs\\nMatrix event routing\\nroom allowlists\\napprovals\\nhandoff parsing\"]\n        WEBHOOKS[\"Webhook platforms\\nHMAC-signed POSTs\\nfrom post-memo.sh\\n(FCT060)\"]\n    end\n\n    subgraph AGENTS[\"Live Persona Agents\"]\n        BOOT[\"Boot\\nOps Lead\\nbridges all spaces\"]\n        KELK[\"Kelk\\nPersonal\"]\n        IG88[\"IG-88\\nTrading\\n@chrislyons-only ACL\"]\n    end\n\n    subgraph RUNTIME[\"Unified Runtime (FCT059 C1b)\"]\n        HERMES[\"Hermes gateway\\nper-agent profile\\nmatrix-nio direct\"]\n    end\n\n    subgraph INFERENCE[\"Inference\"]\n        FACTORY_INF[\"mlx-vlm-factory :41961\\ngemma-4-e4b-it-6bit\\n(Boot + Kelk shared)\"]\n        IG88_INF[\"mlx-vlm-ig88 :41988\\ngemma-4-e4b-it-6bit\\n(IG-88 dedicated)\"]\n        REASON[\"Reasoning 9B\\n:41966\\n(on-demand)\"]\n    end\n\n    COORD -->|\"Matrix route\"| BOOT\n    COORD -->|\"Matrix route\"| KELK\n    COORD -->|\"Matrix route\"| IG88\n    WEBHOOKS -->|\":41951\"| BOOT\n    WEBHOOKS -->|\":41952\"| KELK\n    WEBHOOKS -->|\":41977\"| IG88\n\n    BOOT <-->|\">> handoff\"| KELK\n    BOOT <-->|\">> handoff\"| IG88\n\n    BOOT --> HERMES\n    KELK --> HERMES\n    IG88 --> HERMES\n    HERMES --> FACTORY_INF\n    HERMES --> IG88_INF\n    HERMES -.-> REASON\n\n    classDef coord fill:#276749,stroke:#1c4532,color:#fff\n    classDef webhook fill:#2b6cb0,stroke:#2c5282,color:#fff\n    classDef lead fill:#e94560,stroke:#c73e54,color:#fff\n    classDef agent fill:#805ad5,stroke:#6b46c1,color:#fff\n    classDef runtime fill:#38a169,stroke:#276749,color:#fff\n    classDef local fill:#533483,stroke:#422669,color:#fff\n    classDef ondemand fill:#d69e2e,stroke:#b7791f,color:#000\n    classDef input fill:#319795,stroke:#285e61,color:#fff\n\n    class COORD coord\n    class WEBHOOKS webhook\n    class BOOT lead\n    class KELK,IG88 agent\n    class HERMES runtime\n    class FACTORY_INF,IG88_INF local\n    class REASON ondemand\n    class MSG input"</script></div></div></article></div></section><section class="section-block" data-section="autonomous-loops"><div class="section-heading"><span>Autonomous Loops</span></div><div class="diagram-stack"><article class="surface-card diagram-card" id="autoscope-governance" data-diagram-id="autoscope-governance"><button class="diagram-header" type="button" aria-expanded="true"><span class="diagram-arrow">&#9660;</span><span class="diagram-header__copy"><span class="diagram-title">autoscope — Loop Governance</span><p class="diagram-description">Pre-flight scoping: frozen harness, mutable surface, scalar metric (ATR002, FCT009)</p></span><span class="diagram-kind">FLOWCHART</span></button><div class="diagram-content"><div class="diagram-canvas"><div class="diagram-loading">Rendering diagram...</div><script type="application/json" class="mermaid-source">"flowchart TD\n    PROPOSAL[\"Loop Proposal\\n(agent or human)\"]\n    AUTOSCOPE[\"autoscope\\npre-flight agent\"]\n\n    subgraph SPEC[\"Loop Spec (YAML)\"]\n        FROZEN[\"Frozen Harness\\ncoordinator-rs\\nsoul.md, principles.md\\ntest files, security\"]\n        MUTABLE[\"Mutable Surface\\nnarrowly scoped files\\nthe agent may change\"]\n        METRIC[\"Scalar Metric\\nmachine-readable\\nungameable\"]\n    end\n\n    subgraph LOOPS[\"5 Loop Types\"]\n        L1[\"Researcher\\nresearch_signal_density\\nGate: none\"]\n        L2[\"Narrative (IG-88)\\nnarrative_accuracy_rate\\nGate: none\"]\n        L3[\"Infra-Improve (Boot)\\napproval_friction_rate\\nGate: human before merge\"]\n        L4[\"Coding (Ralph)\\ntest_pass_delta\\nGate: every 5 iterations\"]\n        L5[\"Research Swarm\\nsynthesis_coverage\\nGate: human before promote\"]\n    end\n\n    REJECT[\"Reject\\n(harness incomplete\\nor metric gameable)\"]\n    APPROVE[\"Approved Loop Spec\\nstored in loop-specs/\\n+ Graphiti\"]\n\n    PROPOSAL --> AUTOSCOPE\n    AUTOSCOPE --> FROZEN\n    AUTOSCOPE --> MUTABLE\n    AUTOSCOPE --> METRIC\n    SPEC -->|\"pass\"| APPROVE\n    SPEC -->|\"fail\"| REJECT\n    APPROVE --> L1\n    APPROVE --> L2\n    APPROVE --> L3\n    APPROVE --> L4\n    APPROVE --> L5\n\n    classDef proposal fill:#d69e2e,stroke:#b7791f,color:#000\n    classDef scope fill:#319795,stroke:#285e61,color:#fff\n    classDef spec fill:#533483,stroke:#422669,color:#fff\n    classDef loop fill:#2b6cb0,stroke:#2c5282,color:#fff\n    classDef reject fill:#c53030,stroke:#9b2c2c,color:#fff\n    classDef approve fill:#38a169,stroke:#276749,color:#fff\n\n    class PROPOSAL proposal\n    class AUTOSCOPE scope\n    class FROZEN,MUTABLE,METRIC spec\n    class L1,L2,L3,L4,L5 loop\n    class REJECT reject\n    class APPROVE approve"</script></div></div></article><article class="surface-card diagram-card" id="autonomous-loop-phases" data-diagram-id="autonomous-loop-phases"><button class="diagram-header" type="button" aria-expanded="true"><span class="diagram-arrow">&#9660;</span><span class="diagram-header__copy"><span class="diagram-title">Autonomous Loop Roadmap</span><p class="diagram-description">Loop deployment status — all designed, none yet live (engine: 41 tests, ATR005/006)</p></span><span class="diagram-kind">FLOWCHART</span></button><div class="diagram-content"><div class="diagram-canvas"><div class="diagram-loading">Rendering diagram...</div><script type="application/json" class="mermaid-source">"flowchart LR\n  subgraph ENGINE[\"Loop Engine (coordinator-rs)\"]\n    ENG[\"loop_engine.rs\\n41 tests passing\\nLoop Spec loader\\nlifecycle events\\nbudget enforcement\"]\n  end\n\n  subgraph DESIGNED[\"Designed — Not Yet Live\"]\n    RESEARCHER[\"Researcher Loop\\nLoop Spec: approved\\nATR006 operator guide\\nBlocked: targets retired\\nBlackbox infra\"]\n    IG88_LOOP[\"IG-88 Narrative Loop\\ntimer.rs self-schedule\\nNo Loop Spec produced\\nMetric not operationalized\"]\n    CODING[\"Coding Loop (Ralph)\\ntest_pass_delta metric\\nscope-coding-loop skill\\nDesigned only\"]\n    BOOT_LOOP[\"Boot Self-Improvement\\napproval_friction_rate\\nscope-infra-loop skill\\nDesigned only\"]\n  end\n\n  subgraph DEFERRED[\"Deferred\"]\n    SWARM[\"Research Swarm\\nrequires tokio::spawn\\nscope-swarm skill\\nSpec only\"]\n  end\n\n  ENG -->|\"executes\"| DESIGNED\n  ENG -->|\"future\"| DEFERRED\n  RESEARCHER -->|\"artifact\"| MEM[\"Memory Store\\nQdrant + Graphiti\"]\n  IG88_LOOP -->|\"narrative facts\"| MEM\n  CODING -->|\"git commit/reset\"| REPO[\"Target Repo\"]\n  BOOT_LOOP -->|\"proposed change\"| HGATE[\"Human Gate\\nMatrix reaction\"]\n  HGATE -->|\"approved\"| DEPLOY[\"git merge\\n+ restart\"]\n\n  classDef engine fill:#276749,stroke:#1c4532,color:#fff\n  classDef designed fill:#d69e2e,stroke:#b7791f,color:#000\n  classDef deferred fill:#533483,stroke:#422669,color:#fff\n  classDef storage fill:#2b6cb0,stroke:#2c5282,color:#fff\n  classDef gate fill:#e94560,stroke:#c73e54,color:#fff\n  classDef deploy fill:#319795,stroke:#285e61,color:#fff\n\n  class ENG engine\n  class RESEARCHER,IG88_LOOP,CODING,BOOT_LOOP designed\n  class SWARM deferred\n  class MEM,REPO storage\n  class HGATE gate\n  class DEPLOY deploy"</script></div></div></article><article class="surface-card diagram-card" id="loop-execution-cycle" data-diagram-id="loop-execution-cycle"><button class="diagram-header" type="button" aria-expanded="true"><span class="diagram-arrow">&#9660;</span><span class="diagram-header__copy"><span class="diagram-title">Loop Execution Cycle</span><p class="diagram-description">Modify-commit-evaluate pattern within a Loop Spec's boundaries (Karpathy model)</p></span><span class="diagram-kind">FLOWCHART</span></button><div class="diagram-content"><div class="diagram-canvas"><div class="diagram-loading">Rendering diagram...</div><script type="application/json" class="mermaid-source">"flowchart TD\n    LOOPSPEC[\"Loop Spec\\n(from autoscope)\"]\n\n    subgraph BOUNDARIES[\"Spec Boundaries\"]\n        HARNESS[\"Frozen Harness\\n(untouchable)\"]\n        SURFACE[\"Mutable Surface\\n(agent's sandbox)\"]\n    end\n\n    SPAWN[\"Spawn ephemeral session\\n(tmux + budget clock)\"]\n    MODIFY[\"Modify\\nmutable surface only\"]\n    COMMIT[\"git commit\\nsnapshot state\"]\n    EVALUATE[\"Evaluate\\nscalar metric\\nagainst frozen harness\"]\n    IMPROVED{\"Metric\\nimproved?\"}\n    KEEP[\"Keep commit\\nlog improvement\"]\n    ROLLBACK[\"git reset\\nrevert to last good\"]\n    GATE{\"Approval\\ngate?\"}\n    HUMAN[\"Human gate\\nMatrix reaction\"]\n    BUDGET{\"Budget\\nremaining?\"}\n    TERMINATE[\"Terminate session\\npost summary to Matrix\"]\n\n    LOOPSPEC --> BOUNDARIES\n    BOUNDARIES --> SPAWN\n    SPAWN --> MODIFY\n    MODIFY --> COMMIT\n    COMMIT --> EVALUATE\n    EVALUATE --> IMPROVED\n    IMPROVED -->|\"yes\"| KEEP\n    IMPROVED -->|\"no\"| ROLLBACK\n    KEEP --> GATE\n    ROLLBACK --> GATE\n    GATE -->|\"none\"| BUDGET\n    GATE -->|\"required\"| HUMAN\n    HUMAN -->|\"approved\"| BUDGET\n    HUMAN -->|\"denied\"| TERMINATE\n    BUDGET -->|\"yes\"| MODIFY\n    BUDGET -->|\"no\"| TERMINATE\n\n    classDef spec fill:#319795,stroke:#285e61,color:#fff\n    classDef boundary fill:#533483,stroke:#422669,color:#fff\n    classDef exec fill:#2b6cb0,stroke:#2c5282,color:#fff\n    classDef decision fill:#d69e2e,stroke:#b7791f,color:#000\n    classDef keep fill:#38a169,stroke:#276749,color:#fff\n    classDef rollback fill:#c53030,stroke:#9b2c2c,color:#fff\n    classDef gate fill:#e94560,stroke:#c73e54,color:#fff\n    classDef terminal fill:#718096,stroke:#4a5568,color:#fff\n\n    class LOOPSPEC spec\n    class HARNESS,SURFACE boundary\n    class SPAWN,MODIFY,COMMIT,EVALUATE exec\n    class IMPROVED,GATE,BUDGET decision\n    class KEEP keep\n    class ROLLBACK rollback\n    class HUMAN gate\n    class TERMINATE terminal"</script></div></div></article></div></section><section class="section-block" data-section="infrastructure"><div class="section-heading"><span>Infrastructure</span></div><div class="diagram-stack"><article class="surface-card diagram-card" id="machine-topology" data-diagram-id="machine-topology"><button class="diagram-header" type="button" aria-expanded="true"><span class="diagram-arrow">&#9660;</span><span class="diagram-header__copy"><span class="diagram-title">Machine Topology</span><p class="diagram-description">Four-node Tailscale mesh with Whitebox as primary host</p></span><span class="diagram-kind">FLOWCHART</span></button><div class="diagram-content"><div class="diagram-canvas"><div class="diagram-loading">Rendering diagram...</div><script type="application/json" class="mermaid-source">"flowchart LR\n    CK[\"Cloudkicker\\nMacBook Pro M2\\n100.86.68.16\\nDev workstation\\nDelegate target\"]\n    WB[\"Whitebox\\nMac Studio M2 Max\\n100.88.222.111\\nPrimary inference + services\\ncoordinator-rs, Pantalaimon\\nHermes gateways (Boot/Kelk/IG-88)\\nmlx-vlm, Qdrant, Graphiti, FalkorDB\"]\n    BB[\"Blackbox RP5\\n100.87.53.109\\nWatchdog only\"]\n    R2[\"R2D2\\niPhone\\nElement client\"]\n    TS[\"Tailscale\\nMesh VPN\"]\n    MATRIX[\"matrix.org\\n(external)\"]\n\n    CK <-->|\"WireGuard\"| TS\n    WB <-->|\"WireGuard\"| TS\n    BB <-->|\"WireGuard\"| TS\n    R2 <-->|\"WireGuard\"| TS\n    WB -->|\"E2EE via Pantalaimon\"| MATRIX\n    R2 -->|\"Matrix sync\"| MATRIX\n    CK -->|\"delegate SSH\"| WB\n    BB -->|\"watchdog monitor\"| WB\n\n    classDef mac fill:#d69e2e,stroke:#b7791f,color:#000\n    classDef bb fill:#718096,stroke:#4a5568,color:#fff\n    classDef mobile fill:#805ad5,stroke:#6b46c1,color:#fff\n    classDef net fill:#533483,stroke:#422669,color:#fff\n    classDef ext fill:#718096,stroke:#4a5568,color:#fff\n\n    class CK,WB mac\n    class BB bb\n    class R2 mobile\n    class TS net\n    class MATRIX ext"</script></div></div></article><article class="surface-card diagram-card" id="whitebox-service-map" data-diagram-id="whitebox-service-map"><button class="diagram-header" type="button" aria-expanded="true"><span class="diagram-arrow">&#9660;</span><span class="diagram-header__copy"><span class="diagram-title">Whitebox Service Map</span><p class="diagram-description">Live services and port assignments on Mac Studio M2 Max — post FCT054 / FCT059 / FCT060</p></span><span class="diagram-kind">FLOWCHART</span></button><div class="diagram-content"><div class="diagram-canvas"><div class="diagram-loading">Rendering diagram...</div><script type="application/json" class="mermaid-source">"flowchart LR\n    COORD[\"coordinator-rs\\n(Matrix conductor)\\nno HTTP port\"]\n    PANTA[\"Pantalaimon\\n:41200\\n(Matrix E2EE)\"]\n    QDRANT[\"Qdrant\\n:41450 / :41455\"]\n    FALKOR[\"FalkorDB\\n:41430\"]\n    GRAPHITI[\"Graphiti MCP\\n:41440\"]\n    MATRIX_C[\"Matrix Coord MCP\\n:41400\"]\n    MATRIX_B[\"Matrix Boot MCP\\n:41401\"]\n    QDRANT_MCP[\"Qdrant MCP\\n:41460\"]\n    RESEARCH_MCP[\"Research MCP\\n:41470\"]\n    PORTAL[\"Portal Caddy\\n:41910\"]\n    GSD[\"GSD Sidecar\\n:41911\"]\n    AUTH[\"Auth Sidecar\\n:41914\"]\n    OLLAMA[\"Ollama\\n:11434\\n(embeddings only)\"]\n\n    subgraph HERMES_GW[\"Hermes Gateways (FCT059 C1b)\"]\n        HBOOT[\"hermes-boot\\n@boot.industries\"]\n        HKELK[\"hermes-kelk\\n@sir.kelk\"]\n        HIG88[\"hermes-ig88\\n@ig88bot\"]\n    end\n\n    subgraph WEBHOOKS[\"Factory Conductor Webhooks (FCT060)\"]\n        WH_BOOT[\"Boot webhook\\n127.0.0.1:41951\\n/webhooks/memo\"]\n        WH_KELK[\"Kelk webhook\\n127.0.0.1:41952\\n/webhooks/memo\"]\n        WH_IG88[\"IG-88 webhook\\n127.0.0.1:41977\\n/webhooks/memo\"]\n    end\n\n    subgraph MLX[\"MLX-VLM Inference (FCT054 consolidation)\"]\n        FACTORY_INF[\"mlx-vlm-factory\\n:41961\\ngemma-4-e4b-it-6bit\\n(Boot + Kelk shared)\"]\n        IG88_INF[\"mlx-vlm-ig88\\n:41988\\ngemma-4-e4b-it-6bit\\n(IG-88 dedicated)\"]\n        REASON_INF[\"Reasoning (on-demand)\\n:41966\"]\n    end\n\n    GRAPHITI -->|\"depends\"| FALKOR\n    GRAPHITI -->|\"embeds\"| OLLAMA\n    MATRIX_C -->|\"proxy\"| PANTA\n    MATRIX_B -->|\"proxy\"| PANTA\n    QDRANT_MCP -->|\"query\"| QDRANT\n    RESEARCH_MCP -->|\"query\"| QDRANT\n    COORD -->|\"Matrix E2EE\"| PANTA\n    HBOOT -->|\"matrix-nio\"| PANTA\n    HKELK -->|\"matrix-nio\"| PANTA\n    HIG88 -->|\"matrix-nio\"| PANTA\n    HBOOT --> FACTORY_INF\n    HKELK --> FACTORY_INF\n    HIG88 --> IG88_INF\n    HBOOT -.-> WH_BOOT\n    HKELK -.-> WH_KELK\n    HIG88 -.-> WH_IG88\n    PORTAL -->|\"reverse proxy\"| GSD\n    PORTAL -->|\"auth gate\"| AUTH\n\n    classDef infra fill:#533483,stroke:#422669,color:#fff\n    classDef data fill:#319795,stroke:#285e61,color:#fff\n    classDef mcp fill:#2b6cb0,stroke:#2c5282,color:#fff\n    classDef inference fill:#e94560,stroke:#c73e54,color:#fff\n    classDef gateway fill:#38a169,stroke:#276749,color:#fff\n    classDef webhook fill:#805ad5,stroke:#6b46c1,color:#fff\n    classDef portal fill:#d69e2e,stroke:#b7791f,color:#000\n    classDef sidecar fill:#718096,stroke:#4a5568,color:#fff\n\n    class COORD,PANTA,OLLAMA infra\n    class QDRANT,FALKOR data\n    class GRAPHITI,MATRIX_C,MATRIX_B,QDRANT_MCP,RESEARCH_MCP mcp\n    class FACTORY_INF,IG88_INF,REASON_INF inference\n    class HBOOT,HKELK,HIG88 gateway\n    class WH_BOOT,WH_KELK,WH_IG88 webhook\n    class PORTAL portal\n    class GSD,AUTH sidecar"</script></div></div></article><article class="surface-card diagram-card" id="factory-conductor-webhook" data-diagram-id="factory-conductor-webhook"><button class="diagram-header" type="button" aria-expanded="true"><span class="diagram-arrow">&#9660;</span><span class="diagram-header__copy"><span class="diagram-title">Factory Conductor Webhook Memo Protocol (FCT060)</span><p class="diagram-description">HMAC-signed POSTs from post-memo.sh into each agent's Hermes gateway — localhost-only, secret never on disk</p></span><span class="diagram-kind">SEQUENCE</span></button><div class="diagram-content"><div class="diagram-canvas"><div class="diagram-loading">Rendering diagram...</div><script type="application/json" class="mermaid-source">"sequenceDiagram\n    autonumber\n    participant Chris as Chris (Factory Conductor session)\n    participant Infisical as Infisical<br/>(secret store)\n    participant Post as post-memo.sh<br/>(helper script)\n    participant Gateway as hermes gateway<br/>webhook platform\n    participant Agent as Agent reasoning loop<br/>(Boot / Kelk / IG-88)\n    participant Matrix as Chris&lt;&gt;Agent DM<br/>(Matrix room)\n\n    Chris->>Post: infisical-env.sh factory -- post-memo.sh boot 'memo'\n    Post->>Infisical: fetch WEBHOOK_SECRET_BOOT\n    Infisical-->>Post: secret (injected via env, never on disk)\n    Post->>Post: HMAC-SHA256 sign JSON body<br/>via Python hmac module\n    Post->>Gateway: POST 127.0.0.1:41951/webhooks/memo<br/>X-Webhook-Signature: hex\n    Gateway->>Gateway: verify HMAC against _global_secret<br/>(from os.environ via gateway/config.py:842-855)\n    alt signature valid\n        Gateway-->>Post: 202 Accepted + delivery_id\n        Gateway->>Agent: inject rendered prompt<br/>as user turn<br/>('Factory Conductor memo from Chris...')\n        Agent->>Agent: reason, use tools, compose reply\n        Agent->>Matrix: send_message via matrix-nio\n        Matrix-->>Chris: reply appears in DM\n    else signature invalid\n        Gateway-->>Post: 401 Invalid signature\n    end\n\n    Note over Post,Gateway: Secret lives only in process memory.<br/>Infisical is the sole store.<br/>Rate limit: 30/min per route.<br/>Bind: 127.0.0.1 only (never Tailscale-exposed).\n    Note over Agent: Reply path uses the agent's own<br/>matrix-nio connection — no dependency<br/>on webhook deliver: log fallback."</script></div></div></article></div></section><section class="section-block" data-section="deferred"><div class="section-heading"><span>Deferred</span></div><div class="diagram-stack"><article class="surface-card diagram-card" id="expert-subagent-architecture" data-diagram-id="expert-subagent-architecture"><button class="diagram-header collapsed" type="button" aria-expanded="false"><span class="diagram-arrow">&#9660;</span><span class="diagram-header__copy"><span class="diagram-title">Expert Subagent Pool &amp; Creative Subagents</span><p class="diagram-description">Stub roster — ephemeral expert pool and creative subagents (deferred)</p></span><span class="diagram-kind">FLOWCHART</span></button><div class="diagram-content collapsed"><div class="diagram-canvas"><div class="diagram-loading">Rendering diagram...</div><script type="application/json" class="mermaid-source">"flowchart LR\n    COORD[\"coordinator-rs\"]\n\n    subgraph EXEC_POOL[\"Expert Subagent Pool\\n(ephemeral, 1 instance)\"]\n        RESEARCHER[\"Researcher\"]\n        CODER[\"Coder\"]\n        ADMIN[\"Admin\"]\n        POLICY[\"Policy\"]\n    end\n\n    subgraph CREATIVE[\"Creative Subagents\\n[human gate]\"]\n        C_AUDIO[\"Audio\"]\n        C_VIDEO[\"Video\"]\n        C_MUSIC[\"Music\"]\n        C_WRITE[\"Writing\"]\n    end\n\n    ARTIFACT[\"Artifact\\n(output)\"]\n\n    COORD --> RESEARCHER\n    COORD --> CODER\n    COORD --> ADMIN\n    COORD --> POLICY\n    COORD -->|\"creative request\"| CREATIVE\n    RESEARCHER & CODER & ADMIN & POLICY --> ARTIFACT\n    CREATIVE --> ARTIFACT\n\n    classDef coord fill:#276749,stroke:#1c4532,color:#fff\n    classDef exec fill:#e94560,stroke:#c73e54,color:#fff\n    classDef creative fill:#805ad5,stroke:#6b46c1,color:#fff\n    classDef output fill:#2b6cb0,stroke:#2c5282,color:#fff\n\n    class COORD coord\n    class RESEARCHER,CODER,ADMIN,POLICY exec\n    class C_AUDIO,C_VIDEO,C_MUSIC,C_WRITE creative\n    class ARTIFACT output"</script></div></div></article></div></section>
